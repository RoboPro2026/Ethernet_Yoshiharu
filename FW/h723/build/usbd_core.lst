1131:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****         (pdev->tclasslist[ClassId].Eps[idx].type == ep_type) && \
1132:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****         (pdev->tclasslist[ClassId].Eps[idx].is_used != 0U))
