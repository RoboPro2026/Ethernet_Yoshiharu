 758:Core/Src/main.c ****   const char *message = "Hello UDP message!\n\r";
 759:Core/Src/main.c **** 
 760:Core/Src/main.c ****   osDelay(1000);
 761:Core/Src/main.c **** 
 762:Core/Src/main.c ****   ip_addr_t PC_IPADDR;
 763:Core/Src/main.c ****   IP_ADDR4(&PC_IPADDR, 192, 168, 1, 1);
 764:Core/Src/main.c **** 
 765:Core/Src/main.c ****   struct udp_pcb *my_udp = udp_new();
 766:Core/Src/main.c ****   udp_connect(my_udp, &PC_IPADDR, 55151);
 767:Core/Src/main.c ****   struct pbuf *udp_buffer = NULL;
 768:Core/Src/main.c **** 
 769:Core/Src/main.c ****   // ネットワークインターフェースの取得
 770:Core/Src/main.c ****   extern struct netif gnetif;
 771:Core/Src/main.c **** 
 772:Core/Src/main.c ****   // リンクが確立するまで待機
 773:Core/Src/main.c ****   CDC_Transmit_HS((uint8_t *)"Waiting for link up...\r\n", strlen("Waiting for link up...\r\n"));
ARM GAS  /var/folders/6z/bj4rvlwn0mvdnknwnn42jd6r0000gn/T//ccR7VDn5.s 			page 15


 774:Core/Src/main.c ****   osDelay(100); // USB CDC送信待ち
 775:Core/Src/main.c **** 
 776:Core/Src/main.c ****   while (!netif_is_link_up(&gnetif))
 777:Core/Src/main.c ****   {
 778:Core/Src/main.c ****     osDelay(100);
 779:Core/Src/main.c ****   }
 780:Core/Src/main.c ****   CDC_Transmit_HS((uint8_t *)"Link is UP!\r\n", strlen("Link is UP!\r\n"));
 781:Core/Src/main.c ****   osDelay(100); // USB CDC送信待ち
 782:Core/Src/main.c **** 
 783:Core/Src/main.c ****   // インターフェースがupするまで待機
 784:Core/Src/main.c ****   while (!netif_is_up(&gnetif))
 785:Core/Src/main.c ****   {
 786:Core/Src/main.c ****     osDelay(100);
 787:Core/Src/main.c ****   }
 788:Core/Src/main.c ****   CDC_Transmit_HS((uint8_t *)"Interface is UP!\r\n", strlen("Interface is UP!\r\n"));
 789:Core/Src/main.c ****   osDelay(100); // USB CDC送信待ち
 790:Core/Src/main.c **** 
 791:Core/Src/main.c ****   // さらに少し待機（ARPテーブル構築のため）
 792:Core/Src/main.c ****   osDelay(2000); // 2秒待機（Rx割り込みが動作するか確認）
 793:Core/Src/main.c **** 
 794:Core/Src/main.c ****   CDC_Transmit_HS((uint8_t *)"Starting UDP...\r\n", strlen("Starting UDP...\r\n"));
 795:Core/Src/main.c ****   osDelay(100);
 796:Core/Src/main.c **** 
 797:Core/Src/main.c ****   /* Infinite loop */
 798:Core/Src/main.c ****   for (;;)
 799:Core/Src/main.c ****   {
 800:Core/Src/main.c ****     // LED点滅など
 801:Core/Src/main.c ****     osDelay(1000);
 802:Core/Src/main.c ****     /* !! PBUF_RAM は正しい動作のために重要です !! */
 803:Core/Src/main.c ****     udp_buffer = pbuf_alloc(PBUF_TRANSPORT, strlen(message), PBUF_RAM);
 804:Core/Src/main.c **** 
 805:Core/Src/main.c ****     if (udp_buffer != NULL)
 806:Core/Src/main.c ****     {
 807:Core/Src/main.c ****       memcpy(udp_buffer->payload, message, strlen(message));
 808:Core/Src/main.c ****       err_t err = udp_send(my_udp, udp_buffer);
 809:Core/Src/main.c ****       pbuf_free(udp_buffer);
 810:Core/Src/main.c **** 
 811:Core/Src/main.c ****       // udp_sendの結果を表示
 812:Core/Src/main.c ****       if (err == ERR_OK)
 813:Core/Src/main.c ****       {
 814:Core/Src/main.c ****         CDC_Transmit_HS((uint8_t *)"UDP sent OK\r\n", strlen("UDP sent OK\r\n"));
 815:Core/Src/main.c ****       }
 816:Core/Src/main.c ****       else
 817:Core/Src/main.c ****       {
 818:Core/Src/main.c ****         char err_msg[50];
 819:Core/Src/main.c ****         snprintf(err_msg, sizeof(err_msg), "UDP send ERROR: %d\r\n", err);
 820:Core/Src/main.c ****         CDC_Transmit_HS((uint8_t *)err_msg, strlen(err_msg));
 821:Core/Src/main.c ****       }
 822:Core/Src/main.c ****     }
 823:Core/Src/main.c ****     else
 824:Core/Src/main.c ****     {
 825:Core/Src/main.c ****       CDC_Transmit_HS((uint8_t *)"udp_buffer is NULL\r\n", strlen("udp_buffer is NULL\r\n"));
 826:Core/Src/main.c ****     }
 827:Core/Src/main.c **** 
 828:Core/Src/main.c ****     HAL_GPIO_TogglePin(LED_1_GPIO_Port, LED_1_Pin);
 829:Core/Src/main.c ****     osDelay(1000);
 830:Core/Src/main.c ****   }
