 382:LWIP/Target/ethernetif.c **** /**
 383:LWIP/Target/ethernetif.c ****  * @brief This function should do the actual transmission of the packet. The packet is
 384:LWIP/Target/ethernetif.c ****  * contained in the pbuf that is passed to the function. This pbuf
 385:LWIP/Target/ethernetif.c ****  * might be chained.
 386:LWIP/Target/ethernetif.c ****  *
 387:LWIP/Target/ethernetif.c ****  * @param netif the lwip network interface structure for this ethernetif
 388:LWIP/Target/ethernetif.c ****  * @param p the MAC packet to send (e.g. IP packet including MAC addresses and type)
 389:LWIP/Target/ethernetif.c ****  * @return ERR_OK if the packet could be sent
 390:LWIP/Target/ethernetif.c ****  *         an err_t value if the packet couldn't be sent
 391:LWIP/Target/ethernetif.c ****  *
 392:LWIP/Target/ethernetif.c ****  * @note Returning ERR_MEM here if a DMA queue of your MAC is full can lead to
 393:LWIP/Target/ethernetif.c ****  *       strange results. You might consider waiting for space in the DMA queue
 394:LWIP/Target/ethernetif.c ****  *       to become available since the stack doesn't retry to send a packet
 395:LWIP/Target/ethernetif.c ****  *       dropped because of memory failure (except for the TCP timers).
 396:LWIP/Target/ethernetif.c ****  */
 397:LWIP/Target/ethernetif.c **** 
 398:LWIP/Target/ethernetif.c **** static err_t low_level_output(struct netif *netif, struct pbuf *p)
 399:LWIP/Target/ethernetif.c **** {
 400:LWIP/Target/ethernetif.c ****   uint32_t i = 0U;
 401:LWIP/Target/ethernetif.c ****   struct pbuf *q = NULL;
 402:LWIP/Target/ethernetif.c ****   err_t errval = ERR_OK;
 403:LWIP/Target/ethernetif.c ****   ETH_BufferTypeDef Txbuffer[ETH_TX_DESC_CNT] = {0};
 404:LWIP/Target/ethernetif.c **** 
 405:LWIP/Target/ethernetif.c ****   memset(Txbuffer, 0, ETH_TX_DESC_CNT * sizeof(ETH_BufferTypeDef));
 406:LWIP/Target/ethernetif.c **** 
 407:LWIP/Target/ethernetif.c ****   for (q = p; q != NULL; q = q->next)
 408:LWIP/Target/ethernetif.c ****   {
 409:LWIP/Target/ethernetif.c ****     if (i >= ETH_TX_DESC_CNT)
 410:LWIP/Target/ethernetif.c ****       return ERR_IF;
 411:LWIP/Target/ethernetif.c **** 
 412:LWIP/Target/ethernetif.c ****     Txbuffer[i].buffer = q->payload;
 413:LWIP/Target/ethernetif.c ****     Txbuffer[i].len = q->len;
 414:LWIP/Target/ethernetif.c **** 
 415:LWIP/Target/ethernetif.c ****     if (i > 0)
 416:LWIP/Target/ethernetif.c ****     {
 417:LWIP/Target/ethernetif.c ****       Txbuffer[i - 1].next = &Txbuffer[i];
 418:LWIP/Target/ethernetif.c ****     }
 419:LWIP/Target/ethernetif.c **** 
 420:LWIP/Target/ethernetif.c ****     if (q->next == NULL)
 421:LWIP/Target/ethernetif.c ****     {
 422:LWIP/Target/ethernetif.c ****       Txbuffer[i].next = NULL;
 423:LWIP/Target/ethernetif.c ****     }
 424:LWIP/Target/ethernetif.c **** 
 425:LWIP/Target/ethernetif.c ****     i++;
 426:LWIP/Target/ethernetif.c ****   }
 427:LWIP/Target/ethernetif.c **** 
 428:LWIP/Target/ethernetif.c ****   TxConfig.Length = p->tot_len;
 429:LWIP/Target/ethernetif.c ****   TxConfig.TxBuffer = Txbuffer;
 430:LWIP/Target/ethernetif.c ****   TxConfig.pData = p;
ARM GAS  /var/folders/6z/bj4rvlwn0mvdnknwnn42jd6r0000gn/T//ccQfuE8W.s 			page 9


 431:LWIP/Target/ethernetif.c **** 
 432:LWIP/Target/ethernetif.c ****   pbuf_ref(p);
 433:LWIP/Target/ethernetif.c **** 
 434:LWIP/Target/ethernetif.c ****   do
 435:LWIP/Target/ethernetif.c ****   {
 436:LWIP/Target/ethernetif.c ****     if (HAL_ETH_Transmit_IT(&heth, &TxConfig) == HAL_OK)
 437:LWIP/Target/ethernetif.c ****     {
 438:LWIP/Target/ethernetif.c ****       errval = ERR_OK;
 439:LWIP/Target/ethernetif.c ****     }
 440:LWIP/Target/ethernetif.c ****     else
 441:LWIP/Target/ethernetif.c ****     {
 442:LWIP/Target/ethernetif.c **** 
 443:LWIP/Target/ethernetif.c ****       if (HAL_ETH_GetError(&heth) & HAL_ETH_ERROR_BUSY)
 444:LWIP/Target/ethernetif.c ****       {
 445:LWIP/Target/ethernetif.c ****         /* Wait for descriptors to become available */
 446:LWIP/Target/ethernetif.c ****         osSemaphoreWait(TxPktSemaphore, ETHIF_TX_TIMEOUT);
 447:LWIP/Target/ethernetif.c ****         HAL_ETH_ReleaseTxPacket(&heth);
 448:LWIP/Target/ethernetif.c ****         errval = ERR_BUF;
 449:LWIP/Target/ethernetif.c ****       }
 450:LWIP/Target/ethernetif.c ****       else
 451:LWIP/Target/ethernetif.c ****       {
 452:LWIP/Target/ethernetif.c ****         /* Other error */
 453:LWIP/Target/ethernetif.c ****         pbuf_free(p);
 454:LWIP/Target/ethernetif.c ****         errval = ERR_IF;
 455:LWIP/Target/ethernetif.c ****       }
 456:LWIP/Target/ethernetif.c ****     }
 457:LWIP/Target/ethernetif.c ****   } while (errval == ERR_BUF);
 458:LWIP/Target/ethernetif.c **** 
 459:LWIP/Target/ethernetif.c ****   return errval;
 460:LWIP/Target/ethernetif.c **** }
