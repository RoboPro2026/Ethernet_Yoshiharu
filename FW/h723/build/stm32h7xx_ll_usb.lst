  95:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     if (cfg.use_external_vbus == 1U)
  96:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
