 276:USB_DEVICE/App/usbd_cdc_if.c **** /**
 277:USB_DEVICE/App/usbd_cdc_if.c ****   * @brief  Data to send over USB IN endpoint are sent over CDC interface
 278:USB_DEVICE/App/usbd_cdc_if.c ****   *         through this function.
 279:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Buf: Buffer of data to be sent
 280:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Len: Number of data to be sent (in bytes)
 281:USB_DEVICE/App/usbd_cdc_if.c ****   * @retval Result of the operation: USBD_OK if all operations are OK else USBD_FAIL or USBD_BUSY
 282:USB_DEVICE/App/usbd_cdc_if.c ****   */
 283:USB_DEVICE/App/usbd_cdc_if.c **** uint8_t CDC_Transmit_HS(uint8_t* Buf, uint16_t Len)
 284:USB_DEVICE/App/usbd_cdc_if.c **** {
 285:USB_DEVICE/App/usbd_cdc_if.c ****   uint8_t result = USBD_OK;
 286:USB_DEVICE/App/usbd_cdc_if.c ****   /* USER CODE BEGIN 12 */
 287:USB_DEVICE/App/usbd_cdc_if.c ****   USBD_CDC_HandleTypeDef *hcdc = (USBD_CDC_HandleTypeDef *)hUsbDeviceHS.pClassData;
 288:USB_DEVICE/App/usbd_cdc_if.c ****   if (hcdc->TxState != 0)
 289:USB_DEVICE/App/usbd_cdc_if.c ****   {
 290:USB_DEVICE/App/usbd_cdc_if.c ****     return USBD_BUSY;
 291:USB_DEVICE/App/usbd_cdc_if.c ****   }
 292:USB_DEVICE/App/usbd_cdc_if.c ****   USBD_CDC_SetTxBuffer(&hUsbDeviceHS, Buf, Len);
 293:USB_DEVICE/App/usbd_cdc_if.c ****   result = USBD_CDC_TransmitPacket(&hUsbDeviceHS);
 294:USB_DEVICE/App/usbd_cdc_if.c ****   /* USER CODE END 12 */
 295:USB_DEVICE/App/usbd_cdc_if.c ****   return result;
 296:USB_DEVICE/App/usbd_cdc_if.c **** }
