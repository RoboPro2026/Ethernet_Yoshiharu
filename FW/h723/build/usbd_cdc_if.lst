 253:USB_DEVICE/App/usbd_cdc_if.c ****   *         @note
 254:USB_DEVICE/App/usbd_cdc_if.c ****   *         This function will issue a NAK packet on any OUT packet received on
 255:USB_DEVICE/App/usbd_cdc_if.c ****   *         USB endpoint until exiting this function. If you exit this function
 256:USB_DEVICE/App/usbd_cdc_if.c ****   *         before transfer is complete on CDC interface (ie. using DMA controller)
 257:USB_DEVICE/App/usbd_cdc_if.c ****   *         it will result in receiving more data while previous ones are still
 258:USB_DEVICE/App/usbd_cdc_if.c ****   *         not sent.
 259:USB_DEVICE/App/usbd_cdc_if.c ****   *
 260:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Buf: Buffer of data to be received
 261:USB_DEVICE/App/usbd_cdc_if.c ****   * @param  Len: Number of data received (in bytes)
 262:USB_DEVICE/App/usbd_cdc_if.c ****   * @retval Result of the operation: USBD_OK if all operations are OK else USBD_FAILL
 263:USB_DEVICE/App/usbd_cdc_if.c ****   */
 264:USB_DEVICE/App/usbd_cdc_if.c **** static int8_t CDC_Receive_HS(uint8_t* Buf, uint32_t *Len)
 265:USB_DEVICE/App/usbd_cdc_if.c **** {
 266:USB_DEVICE/App/usbd_cdc_if.c ****   /* USER CODE BEGIN 11 */
 267:USB_DEVICE/App/usbd_cdc_if.c ****   USBD_CDC_SetRxBuffer(&hUsbDeviceHS, &Buf[0]);
 268:USB_DEVICE/App/usbd_cdc_if.c ****   USBD_CDC_ReceivePacket(&hUsbDeviceHS);
 269:USB_DEVICE/App/usbd_cdc_if.c **** 
 270:USB_DEVICE/App/usbd_cdc_if.c ****   CDC_Transmit_HS(&Buf[0], 1);
 271:USB_DEVICE/App/usbd_cdc_if.c **** 
 272:USB_DEVICE/App/usbd_cdc_if.c ****   return (USBD_OK);
 273:USB_DEVICE/App/usbd_cdc_if.c ****   /* USER CODE END 11 */
 274:USB_DEVICE/App/usbd_cdc_if.c **** }
