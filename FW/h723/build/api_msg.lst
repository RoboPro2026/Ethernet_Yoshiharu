 948:Middlewares/Third_Party/LwIP/src/api/api_msg.c ****     shut_close = 1;
 949:Middlewares/Third_Party/LwIP/src/api/api_msg.c ****   } else if (shut_tx && ((tpcb->flags & TF_RXCLOSED) != 0)) {
